# Base de datos Postgres (local con Docker o Neon en producción)
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio?schema=public"
# En Neon: usa la conexión "pooler" para DATABASE_URL y la conexión directa (sin
# "-pooler") para DIRECT_URL — las migraciones necesitan la conexión directa.
DIRECT_URL="postgresql://user:password@localhost:5432/portfolio?schema=public"

# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# Credenciales del único usuario admin.
# Genera el hash con: npm run hash-password -- "tu-password"
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""

# Vercel Blob (subida de imágenes/CV) — token del tab "Storage" de tu proyecto en Vercel
BLOB_READ_WRITE_TOKEN=""

# URL pública real del sitio ya desplegado (ej. https://tu-dominio.com)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
